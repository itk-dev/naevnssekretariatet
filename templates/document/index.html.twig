{% extends 'base.html.twig' %}

{% block title %}Hello DocumentController!{% endblock %}

{% block body %}
    {% if documents|length > 0 %}
        <h2>Documents:</h2>
        {% for document in documents %}
            <h4>{{ document.name }} Uploader: {{ document.createdBy }}</h4>
        {% endfor %}
    {% else %}
        <div>No documents have been uploaded yet.</div>
    {% endif %}
    <h2>Upload file:</h2>
    {{ form(document_form) }}
{% endblock %}
