{% extends 'base.html.twig' %}

{% block title %}CaseEntity{% endblock %}

{% block body %}
    <h1>CaseEntity</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ case_entity.id }}</td>
            </tr>
            <tr>
                <th>CaseType</th>
                <td>{{ case_entity.caseType }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ case_entity.createdAt ? case_entity.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>CaseNumber</th>
                <td>{{ case_entity.caseNumber }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('case_index') }}">back to list</a>

    <a href="{{ path('case_edit', {'id': case_entity.id}) }}">edit</a>

    {{ include('case/_delete_form.html.twig') }}
{% endblock %}
